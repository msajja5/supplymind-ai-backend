{
  "name": "supplymind-ai-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "SupplyMind AI — Supply Chain ESG + Carbon Backend",
  "main": "server.js",
  "scripts": {
    "start":     "node server.js",
    "dev":       "node --watch server.js",
    "test":      "node --experimental-vm-modules node_modules/.bin/jest --forceExit",
    "test:e2e":  "node --experimental-vm-modules node_modules/.bin/jest tests/e2e.test.js --verbose --forceExit",
    "validate":  "node --experimental-vm-modules node_modules/.bin/jest --forceExit && echo '\u2705 All checks passed'"
  },
  "dependencies": {
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "transform":       {},
    "extensionsToTreatAsEsm": [".js"]
  }
}
