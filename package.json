{
  "name": "supplymind-ai-backend",
  "version": "2.0.0",
  "description": "SupplyMind AI — Real-time ESG data pipeline. WhatsApp + Camera + PDF → ESG Passport + CBAM/CSRD compliance",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start":        "node server.js",
    "dev":          "node server.js",
    "dev:vercel":   "vercel dev",
    "test":         "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern=tests/ --coverage",
    "test:watch":   "node --experimental-vm-modules node_modules/.bin/jest --watch",
    "simulate":     "bash tests/simulate-whatsapp.sh",
    "checklist":    "bash tests/codespaces-checklist.sh"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "@jest/globals": "^29.7.0"
  },
  "jest": {
    "extensionsToTreatAsEsm": [".js"],
    "transform": {}
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
