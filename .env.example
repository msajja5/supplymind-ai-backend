# SupplyMind AI — Environment Variables
# Copy to .env.local for local development

# API Authentication
SUPPLYMIND_API_KEY=sm_your_secret_key_here

# FX Rate Service (ECB via Frankfurter API — free, no key needed)
ECB_FX_API_URL=https://api.frankfurter.app/latest

# EU Buyer Delivery Endpoint
BUYER_API_URL=https://buyer-erp.example.de/api/v1/inbound
BUYER_API_KEY=buyer_secret_key_here

# WhatsApp Cloud API (Meta Business)
WHATSAPP_VERIFY_TOKEN=your_whatsapp_verify_token
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# OCR Service (e.g. Google Vision or AWS Textract)
OCR_SERVICE=google_vision
OCR_API_KEY=your_ocr_api_key

# Emission Factor DB (custom or Climatiq API)
CLIMATIQ_API_KEY=your_climatiq_key

# Optional: External DB (leave blank to use in-memory store)
DATABASE_URL=
