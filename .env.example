# SupplyMind AI — Environment Variables
# Copy to .env.local for local development
# NEVER commit .env.local to git

# ─── Core API ──────────────────────────────────────────────────────────────────
SUPPLYMIND_API_KEY=sm_your_secret_key_here

# ─── WhatsApp Cloud API (Meta Business) ────────────────────────────────────────
# Get from: developers.facebook.com → Your App → WhatsApp → API Setup
WHATSAPP_VERIFY_TOKEN=supplymind_verify_2026
WHATSAPP_ACCESS_TOKEN=your_meta_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_BUSINESS_ACCOUNT_ID=your_waba_id_here

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Get from: supabase.com → Project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── FX Rate (free, no key needed) ─────────────────────────────────────────────
ECB_FX_API_URL=https://api.frankfurter.app/latest

# ─── OCR (optional — leave blank to use regex extractor) ───────────────────────
# Options: google_vision | aws_textract | none
OCR_SERVICE=none
OCR_API_KEY=

# ─── OpenAI (optional — for AI-enhanced ESG extraction) ────────────────────────
OPENAI_API_KEY=

# ─── Climatiq Emission Factors (optional — free tier available) ─────────────────
CLIMATIQ_API_KEY=

# ─── EU Buyer Delivery Endpoint ────────────────────────────────────────────────
BUYER_API_URL=https://buyer-erp.example.de/api/v1/inbound
BUYER_API_KEY=buyer_secret_key_here

# ─── ngrok (optional — for local webhook testing) ──────────────────────────────
# Get free token from: ngrok.com → Sign up → Your Authtoken
NGROK_AUTHTOKEN=

# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
